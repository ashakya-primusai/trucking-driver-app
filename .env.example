# Firebase (driver-app web client — keys are public; restrict in Firebase Console)
#
# Local: copy this file to .env.local and fill values from Firebase Console
#   → Project settings → Your apps → Web app → SDK setup and configuration
#
# Vercel: Project → Settings → Environment Variables — add every NEXT_PUBLIC_FIREBASE_*
#   below for Production (and Preview). Redeploy after saving (NEXT_PUBLIC_* is inlined at build).
#
# Required once per project: Firebase Console → Build → Authentication → Get started
# (fixes auth/configuration-not-found on login). No sign-in providers need to be enabled.
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=
NEXT_PUBLIC_FIREBASE_DATABASE_URL=https://YOUR_PROJECT_ID-default-rtdb.firebaseio.com

# Backend API (optional)
# NEXT_PUBLIC_API_BASE_URL=http://localhost:3001
# NEXT_PUBLIC_API_URL=http://localhost:3001
